# ============================================
# CONFIGURACIÓN LLM - ENTREGABLE 2
# ============================================
# Copia este archivo a .env y rellena con tus valores
# NO incluyas este archivo en git (.gitignore ya lo protege)

# Proveedor LLM: azure_openai, openai, anthropic
LLM_PROVIDER=azure_openai

# Azure OpenAI / OpenAI configuration
LLM_API_KEY=<tu_api_key>
LLM_ENDPOINT=https://<tu_endpoint>
LLM_MODEL=gpt-5.4-nano
LLM_API_VERSION=2024-12-01-preview

# Timeout para llamadas al LLM (segundos)
LLM_TIMEOUT=30

# Reintentos en caso de fallo
LLM_MAX_RETRIES=3

# Configuración de la API
APP_HOST=127.0.0.1
APP_PORT=8000

